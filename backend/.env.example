# breath_analyzer configuration variables
# Please copy this file to `.env` and fill in the blanks

# 1. Database Configuration (Required for the API to start)
# Set your TimescaleDB / PostgreSQL username and password here.
POSTGRES_USER=postgres
SUPABASE_URL=
SUPABASE_KEY=
WAQI_TOKEN=
GROQ_API_KEY=
GEMINI_API_KEY=your_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=breath_analyzer

# 2. Redis Configuration (Required for Background Satellite Task Processing)
# Points to a running local redis server, used by Celery.
CELERY_BROKER_URL=redis://localhost:6379/0

# 3. Google Earth Engine Service Account (Required for Satellite Processing)
# Earth Engine doesn't use simple "API Keys". Instead, you need a Service Account JSON file.
# Path to your Google Cloud service account JSON credentials file.
# e.g., EE_SERVICE_ACCOUNT_CREDENTIALS=/app/keys/earth_engine_key.json
EE_SERVICE_ACCOUNT_CREDENTIALS=
